{
  "AB6_SNP_SNP_HW_01": {
    "name": "Sensor State Identification",
    "description": "Observe live sensor streams from ROBOX-SNP and identify what each data stream measures",
    "parameters": {
      "num_sensors": 14,
      "max_time": 600.0
    },
    "success_criteria": {
      "min_correct_sensors": 10
    },
    "performance_metrics": {
      "accuracy": "number of sensors correctly identified",
      "time": "time to complete"
    }
  },
  "AB6_SNP_SNP_HW_02": {
    "name": "Sensor Output Nature",
    "description": "ROBOX-SNP live streams: Part 1 signal type (reading + analog/digital), Part 2 sensor name and unit",
    "type": "hardware",
    "parameters": {
      "streams": 14,
      "max_time": 600.0
    },
    "success_criteria": {
      "min_score_percent": 60
    },
    "performance_metrics": {
      "accuracy": "per-dropdown correctness across both parts",
      "time": "time to complete"
    }
  },
  "AB6_SNP_SNP_QZ_03": {
    "name": "Sensor Principles Quiz",
    "description": "Internal quiz; GUI-driven.",
    "type": "course",
    "parameters": {}
  },
  "AB6_CON_RBX_HW_004": {
    "name": "Position Control with PD Tuning",
    "description": "Control a single joint with PD tuning",
    "parameters": {
      "target_angle": {
        "default": 1.57,
        "min": -2.618,
        "max": 2.618
      },
      "kp": {
        "default": 10.0,
        "min": 0.0,
        "max": 16500.0
      },
      "kd": {
        "default": 1.0,
        "min": 0.0,
        "max": 10.0
      },
      "max_time": 5.0,
      "dt": 0.01
    },
    "success_criteria": {
      "settling_time": 3.0,
      "max_overshoot": 20.0,
      "steady_state_error": 0.02
    },
    "performance_metrics": {
      "settling_time": "time to reach within 2% of target",
      "overshoot": "maximum overshoot percentage",
      "steady_state_error": "final position error"
    }
  },
  "AB6_SNP_SNP_HW_05": {
    "name": "Sense It Your Way",
    "description": "SNP distance challenge; GUI-driven.",
    "type": "course",
    "parameters": {}
  },
  "AB6_SNP_SNP_HW_06": {
    "name": "The Right Sensor for the Right Job",
    "description": "Maze navigation with code editor; mentor-evaluated (same runner pattern as timed lab challenges)",
    "type": "target_pointing",
    "parameters": {
      "target_position": {
        "x": 0.0,
        "y": 0.25,
        "z": 0.0
      },
      "target_tolerance": 0.01,
      "max_duration": 60,
      "visualization_update_rate": 0.1
    },
    "success_criteria": {
      "min_percent_on_target": 60,
      "max_pointing_error": 0.02
    },
    "performance_metrics": {
      "percent_on_target": "percentage of time pointing at target within tolerance",
      "mean_pointing_error": "average pointing error in meters",
      "max_pointing_error": "maximum pointing error in meters"
    },
    "evaluation": {
      "score_tiers": [
        {
          "threshold": 95,
          "score": 100,
          "description": "Excellent navigation / sensing choices"
        },
        {
          "threshold": 80,
          "score": 90,
          "description": "Very good"
        },
        {
          "threshold": 60,
          "score": 75,
          "description": "Good"
        },
        {
          "threshold": 40,
          "score": 60,
          "description": "Fair"
        }
      ],
      "default_score": 0
    }
  },
